{
  "name": "kysely-opentelemetry",
  "version": "0.1.1",
  "description": "OpenTelemetry instrumentation for Kysely: semconv-compliant spans and metrics with stable query grouping keys",
  "license": "MIT",
  "author": "Carlos Cima",
  "homepage": "https://github.com/camcima/kysely-opentelemetry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camcima/kysely-opentelemetry.git"
  },
  "bugs": {
    "url": "https://github.com/camcima/kysely-opentelemetry/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "kysely",
    "opentelemetry",
    "otel",
    "tracing",
    "observability",
    "sql",
    "database"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run test/unit test/otel",
    "test:unit": "vitest run test/unit test/otel",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run test/unit test/otel --coverage --reporter=default --reporter=junit --outputFile=test-report.junit.xml",
    "test:integration:coverage": "vitest run test/integration --coverage --reporter=default --reporter=junit --outputFile=test-report.integration.junit.xml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync-version": "node scripts/sync-version.mjs",
    "release": "release-it",
    "prepublishOnly": "pnpm run build",
    "prepare": "lefthook install",
    "security:audit": "pnpm audit --prod",
    "security:secrets": "gitleaks detect --no-banner"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.8",
    "kysely": ">=0.27 <0.30"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@testcontainers/mssqlserver": "^12.0.4",
    "@testcontainers/mysql": "^12.0.4",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "better-sqlite3": "^12.11.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "kysely": "0.29.3",
    "lefthook": "^2.1.9",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "prettier": "^3.9.4",
    "release-it": "^20.2.1",
    "tarn": "^3.1.0",
    "tedious": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "lefthook"
    ]
  }
}
