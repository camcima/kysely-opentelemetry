{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": ["pnpm run lint", "pnpm test"],
    "after:bump": ["pnpm run sync-version", "pnpm run build"]
  }
}
